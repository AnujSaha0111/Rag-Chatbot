# RAG Chatbot Configuration
# Copy this file to .env and add your API keys

# Choose embedding model type: "openai", "huggingface", or "groq"
EMBEDDING_MODEL_TYPE=model_selection

# OpenAI API Key (required if using openai)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=add_your_key_here

# HuggingFace API Key (required if using huggingface)
# Get it from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=add_your_key_here

# Groq API Key (optional - for groq LLM, embeddings use local models)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=add_your_key_here
